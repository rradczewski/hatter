{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests"
  ],
  "dependencyDashboard": true,
  "automerge": true,
  "automergeType": "branch",
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "matchFileNames": [
        ".github/**",
        ".github/*"
      ],
      "minimumReleaseAge": "30 days"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)render\\.sh$/"
      ],
      "matchStrings": [
        "BASE_IMAGE=(?<depName>[a-z0-9.\\-/]+):(?<currentValue>[\\w.\\-]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ]
}
