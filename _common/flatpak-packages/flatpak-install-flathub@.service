[Unit]
Description=Install Flatpak app %I from Flathub
Documentation=man:flatpak(1)
After=network-online.target flatpak-remote-flathub.service
Wants=network-online.target
ConditionPathExists=!/var/flatpak-install/flathub-%i
Requires=flatpak-remote-flathub.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/bin/sh -c 'flatpak info --system %I >/dev/null 2>&1 \
    || flatpak install --system --noninteractive --assumeyes flathub %I'
ExecStartPost=/bin/touch /var/flatpak-install/flathub-%i

[Install]
WantedBy=multi-user.target